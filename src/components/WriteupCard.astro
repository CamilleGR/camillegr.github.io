---
/**
 * Carte de writeup : illustration centrée, titre, courte description.
 * Liseré vert pour HackTheBox, liseré rouge pour TryHackMe.
 *
 * Usage :
 * <WriteupCard
 *   platform="hackthebox"
 *   title="Box — Élévation de privilèges Linux"
 *   description="Cron mal configuré exploité pour un accès root."
 *   image={boxIcon}
 *   href="/writeups/hackthebox/exemple-privesc-linux/"
 * />
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
	platform: 'hackthebox' | 'tryhackme';
	title: string;
	image: ImageMetadata | string;
	imageAlt?: string;
	href: string;
}

const { platform, title, image, imageAlt = title, href } = Astro.props;
const isLocalImage = typeof image !== 'string';
const platformLabel = platform === 'hackthebox' ? 'HackTheBox' : 'TryHackMe';
---

<a class="writeup-card" data-platform={platform} href={href}>
	<span class="writeup-card__tag">{platformLabel}</span>

	<div class="writeup-card__illustration">
		{
			isLocalImage ? (
				<Image src={image as ImageMetadata} alt={imageAlt} width={160} height={160} />
			) : (
				<img src={image as string} alt={imageAlt} width="160" height="160" loading="lazy" />
			)
		}
	</div>

	<p class="writeup-card__title">{title}</p>
</a>
